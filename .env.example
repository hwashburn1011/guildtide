# ---------------------------------------------------------------------------
# Environment Variables — Guildtide (T-1897, T-1906)
# Copy to .env and fill in values. NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=4000

# Auth / JWT
JWT_SECRET=change-this-to-a-real-secret
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL="file:./server/prisma/dev.db"

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=./logs

# Cache
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1000

# External APIs
OPENWEATHERMAP_API_KEY=
FINANCE_API_KEY=

# Monitoring (optional)
SENTRY_DSN=
WEBHOOK_SECRET=

# Feature Flags
FF_CRON_JOBS=true
FF_BACKGROUND_WORKERS=true
FF_API_DOCS=true
FF_METRICS=true
